.task
bin
# Stray root binary from `go build .` (without -o) — module name is
# lowercase formidable2 so plain go build drops it here.
/formidable2
frontend/dist/*
!frontend/dist/.gitkeep
frontend/node_modules
build/linux/appimage/build
build/windows/nsis/MicrosoftEdgeWebview2Setup.exe

# Runtime user data: lives under context_folder which defaults to ./Examples
# in dev. The Examples/ tree is dev-only sample data and never tracked.
Examples/

# Local config (per-machine; first-run default points at Examples/).
# Anchored to repo root so internal/modules/config/ stays tracked.
/config/

# Stale roots from earlier dev runs before context_folder defaulted to
# Examples — keep ignored so we don't accidentally commit them.
/templates/
/storage/
/.changes.log
/.changes.cursor

# Per-profile SQLite index cache. Derived view of the on-disk
# templates/storage tree — regenerated by RescanAll on startup.
/index/

formidable.log
.DS_Store
.idea/
.vscode/
*.swp
.changes.*
**/.changes.*
